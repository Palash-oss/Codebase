{
  "framework": "vite",
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/upload",
      "destination": "/api/index.js"
    },
    {
      "source": "/github",
      "destination": "/api/index.js"
    },
    {
      "source": "/chat",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/((?!upload|github|chat|api|assets|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
